# ---------- تلگرام ----------
# توکن رباتی که از BotFather می‌گیری
TELEGRAM_BOT_TOKEN=
# آیدی عددی ادمین‌ها (با کاما جدا کن) — برای ارجاع به اپراتور و هشدارها
ADMIN_USER_IDS=

# ---------- ووکامرس ----------
# آدرس فروشگاه بدون اسلش انتها، مثلا https://example-store.com
WOO_URL=
WOO_CK=
WOO_CS=

# ---------- جی‌پی‌تی (OpenAI) ----------
OPENAI_API_KEY=
# مدل پیش‌فرض؛ برای کیفیت بالاتر gpt-4o بگذار، برای ارزان‌تر gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.4

# ---------- نمایش قیمت ----------
# واحد فروشگاه ریال است؛ برای نمایش تومان بر ۱۰ تقسیم می‌شود. برای نمایش ریال ۱ بگذار
MONEY_DIVISOR=10
CURRENCY_LABEL=تومان

# ---------- رفتار دستیار ----------
# بیشینه پیام‌های نگه‌داشته‌شده در حافظه‌ی هر گفتگو (پرسش+پاسخ)
MAX_HISTORY_TURNS=12
# بیشینه دور فراخوانی ابزار در هر پاسخ
MAX_TOOL_ROUNDS=5

# ---------- وب‌سرور چت سایت ----------
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8090
# دامنه‌هایی که اجازه‌ی اتصال به ویجت چت دارند (با کاما)، یا * برای همه
WEB_ALLOWED_ORIGINS=*
